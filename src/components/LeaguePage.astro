---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  name: string;
  day: string;
  time?: string;
  description?: string;
  keyFileUrl?: string;
}

const { name, day, time, description, keyFileUrl } = Astro.props;
---

<BaseLayout title={name}>
  <section class="section">
    <div class="container">
      <div class="league-header">
        <span class="league-day">{day}</span>
        <h1>{name}</h1>
        {time && <p class="league-time">{time}</p>}
        {description && <p class="league-desc">{description}</p>}
      </div>

      <div class="league-content">
        <div class="main-content">
          <!-- Announcements -->
          <section class="content-section">
            <h2>Announcements</h2>
            <slot name="announcements">
              <p>No current announcements.</p>
            </slot>
          </section>

          <!-- Last Updated -->
          {keyFileUrl && (
            <p class="last-updated" data-key-file={keyFileUrl}>
              <em>Checking for updates...</em>
            </p>
          )}

          <!-- Documents -->
          <section class="content-section">
            <h2>League Reports</h2>
            <slot name="documents">
              <p>No documents available.</p>
            </slot>
          </section>

          <!-- Season Info -->
          <section class="content-section">
            <h2>Season Information</h2>
            <slot name="season-info">
              <p>Season information coming soon.</p>
            </slot>
          </section>
        </div>

        <aside class="sidebar">
          <!-- Quick Links -->
          <div class="sidebar-section">
            <h3>Quick Links</h3>
            <ul class="quick-links">
              <li><a href="/leagues/">All Leagues</a></li>
              <li><a href="https://www.chronogolf.com/club/15033/widget?medium=widget&source=club" target="_blank" rel="noopener">Book a Tee Time</a></li>
              <li><a href="/contact/">Contact Us</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const el = document.querySelector<HTMLElement>('.last-updated[data-key-file]');
  if (el) {
    const url = el.dataset.keyFile!;
    fetch(url, { method: 'HEAD' })
      .then(res => {
        const lastMod = res.headers.get('last-modified');
        if (lastMod) {
          const date = new Date(lastMod).toLocaleDateString('en-US', {
            month: 'long', day: 'numeric', year: 'numeric',
            hour: 'numeric', minute: '2-digit'
          });
          el.innerHTML = `<em>Last Updated – ${date}</em>`;
        } else {
          el.remove();
        }
      })
      .catch(() => el.remove());
  }
</script>

<style>
  .league-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .league-day {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }

  .league-header h1 {
    margin-bottom: 0.25rem;
  }

  .league-time {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }

  .league-desc {
    color: var(--color-text-light);
  }

  .league-content {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
  }

  @media (max-width: 900px) {
    .league-content {
      grid-template-columns: 1fr;
    }
  }

  .content-section {
    margin-bottom: 2.5rem;
  }

  .content-section h2 {
    color: var(--color-primary);
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  .last-updated {
    margin-bottom: 1.5rem;
    color: var(--color-text-light);
    font-size: 0.9rem;
  }

  .sidebar-section {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--color-bg-light);
    border-radius: 8px;
  }

  .sidebar-section h3 {
    font-size: 1rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .quick-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .quick-links li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .quick-links li:last-child {
    border-bottom: none;
  }
</style>

<style is:global>
  /* Plain document link list matching production style */
  .league-content .main-content ul {
    padding-left: 1.5rem;
    margin-bottom: 0;
  }

  .league-content .main-content li {
    margin-bottom: 0.25rem;
  }
</style>
