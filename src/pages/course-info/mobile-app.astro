---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Mobile App">
  <section class="section">
    <div class="container">
      <h1>Mobile App</h1>
      <p class="intro">Download the Grand View Golf Club app for convenient access to booking and course information.</p>

      <div class="app-info">
        <div class="features">
          <h2>App Features</h2>
          <ul>
            <li><strong>Book Tee Times</strong> - Reserve your spot up to 6 days in advance</li>
            <li><strong>View Handicap</strong> - Track your GHIN handicap</li>
            <li><strong>Course Info</strong> - Scorecard, yardages, and more</li>
            <li><strong>Push Notifications</strong> - Get alerts about events and specials</li>
          </ul>
        </div>

        <div class="download">
          <h2>Download</h2>
          <div class="download-buttons">
            <!-- TODO: Add actual app store links -->
            <a href="https://apps.apple.com/app/id123456789" target="_blank" rel="noopener noreferrer" class="store-button">
              Download on the App Store
            </a>
            <a href="https://play.google.com/store/apps/details?id=com.example" target="_blank" rel="noopener noreferrer" class="store-button store-button--android">
              Get it on Google Play
            </a>
          </div>
          <p class="note">Search for "Grand View Golf Club" in your app store.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }

  .app-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .app-info {
      grid-template-columns: 1fr;
    }
  }

  .features h2,
  .download h2 {
    color: var(--color-primary);
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .features ul {
    list-style: none;
    padding: 0;
  }

  .features li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .download {
    padding: 2rem;
    background: var(--color-bg-light);
    border-radius: 8px;
    height: fit-content;
  }

  .download-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .store-button {
    display: block;
    padding: 1rem 1.5rem;
    background: #000;
    color: white;
    text-align: center;
    border-radius: 8px;
    font-weight: 500;
  }

  .store-button:hover {
    background: #333;
    text-decoration: none;
    color: white;
  }

  .store-button--android {
    background: var(--color-primary);
  }

  .store-button--android:hover {
    background: var(--color-primary-dark);
  }

  .note {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-light);
  }
</style>
