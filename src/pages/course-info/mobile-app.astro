---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Mobile Apps">
  <section class="section">
    <div class="container">
      <h1>Mobile Apps</h1>
      <p class="subtitle">Download our App for Your iPhone or Android!</p>

      <div class="app-layout">
        <div class="app-screenshot">
          <img src="/images/app-screenshot.png" alt="Grand View Golf Club mobile app screenshot" />
        </div>

        <div class="app-details">
          <h2>Booking Tee Times Was Never Easier!</h2>
          <ul class="features">
            <li>Real-Time Availability</li>
            <li>Lowest Rates</li>
            <li>Pay in Advance</li>
          </ul>

          <div class="store-badges">
            <a href="https://apps.apple.com/us/app/grand-view-gc/id1509068067" target="_blank" rel="noopener noreferrer">
              <img src="/images/badge-appstore.png" alt="Download on the App Store" class="badge" />
            </a>
            <a href="https://play.google.com/store/apps/details?id=com.chronogolf.booking.grandview&hl=en_GB" target="_blank" rel="noopener noreferrer">
              <img src="/images/badge-googleplay.png" alt="Get it on Google Play" class="badge" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .subtitle {
    font-size: 1.2rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }

  .app-layout {
    display: flex;
    gap: 3rem;
    align-items: center;
  }

  .app-screenshot img {
    max-width: 230px;
  }

  .app-details h2 {
    color: var(--color-primary);
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .features {
    list-style: none;
    padding: 0;
    margin-bottom: 2rem;
  }

  .features li {
    padding: 0.5rem 0;
    font-size: 1.1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .features li:last-child {
    border-bottom: none;
  }

  .store-badges {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .badge {
    max-width: 200px;
  }

  .store-badges a:hover {
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .app-layout {
      flex-direction: column;
      text-align: center;
    }

    .store-badges {
      align-items: center;
    }
  }
</style>
