---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Banquet Hall">
  <section class="section">
    <div class="container">
      <h1>Banquet Hall</h1>
      <p class="intro">Host your next event at Grand View Golf Club's clubhouse.</p>

      <div class="content">
        <div class="info">
          <h2>Event Space</h2>
          <p>Our clubhouse offers a welcoming space for your special occasions. Whether you're planning a golf outing, reunion, birthday party, or other celebration, we can accommodate your group.</p>

          <h3>Capacity</h3>
          <p>Up to XX guests</p>

          <h3>Amenities</h3>
          <ul>
            <li>Full bar service</li>
            <li>Catering available</li>
            <li>Scenic views of the course</li>
            <li>Ample parking</li>
          </ul>

          <h3>Perfect For</h3>
          <ul>
            <li>Golf outings</li>
            <li>Corporate events</li>
            <li>Birthday parties</li>
            <li>Reunions</li>
            <li>Retirement parties</li>
            <li>Celebration of life</li>
          </ul>
        </div>

        <div class="cta">
          <h2>Book Your Event</h2>
          <p>Contact us to check availability and discuss your event needs.</p>
          <p><strong>Phone:</strong> <a href="tel:920-779-6421">(920) 779-6421</a></p>
          <a href="/contact/" class="btn">Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }

  .content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .content {
      grid-template-columns: 1fr;
    }
  }

  .info h2 {
    color: var(--color-primary);
    margin-top: 0;
  }

  .info h3 {
    font-size: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .info ul {
    padding-left: 1.5rem;
  }

  .info li {
    margin-bottom: 0.25rem;
  }

  .cta {
    padding: 2rem;
    background: var(--color-bg-light);
    border-radius: 8px;
    height: fit-content;
  }

  .cta h2 {
    color: var(--color-primary);
    font-size: 1.25rem;
    margin-top: 0;
  }
</style>
