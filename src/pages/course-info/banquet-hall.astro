---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Banquet Hall">
  <section class="section">
    <div class="container">
      <h1>Banquet Hall</h1>
      <p class="intro">Host your next event at Grand View Golf Club's clubhouse.</p>

      <div class="content">
        <div class="info">
          <h2>Event Space</h2>
          <p>Grand View Golf Club offers banquet facilities for a wide variety of events. Our venue accommodates over 100 people with customizable setup options to fit your needs.</p>

          <h3>Amenities Included</h3>
          <ul>
            <li>Tables and chairs arranged to your preference</li>
            <li>Selectable tablecloth colors</li>
            <li>Fully stocked bar</li>
            <li>Professional bartenders</li>
          </ul>

          <h3>Permitted Items</h3>
          <p>Guests may bring juice, punch, or coffee. All alcohol, soda, and water bottles must be purchased behind the bar.</p>

          <h3>Perfect For</h3>
          <ul>
            <li>Showers</li>
            <li>Birthday parties</li>
            <li>Wedding receptions</li>
            <li>Family &amp; class reunions</li>
            <li>Christmas parties</li>
            <li>Corporate golf outings</li>
          </ul>

          <p class="outing-note">Tee times are available to precede your event with a family or corporate golf outing!</p>
        </div>

        <div class="cta">
          <h2>Book Your Event</h2>
          <p>Contact us to check availability and discuss your event needs.</p>
          <p><strong>Phone:</strong> <a href="tel:920-779-6421">(920) 779-6421</a></p>
          <p><strong>Email:</strong> <a href="mailto:grandviewbarstaff@gmail.com">grandviewbarstaff@gmail.com</a></p>
          <a href="/contact/" class="btn">Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }

  .content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .content {
      grid-template-columns: 1fr;
    }
  }

  .info h2 {
    color: var(--color-primary);
    margin-top: 0;
  }

  .info h3 {
    font-size: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .info ul {
    padding-left: 1.5rem;
  }

  .info li {
    margin-bottom: 0.25rem;
  }

  .outing-note {
    margin-top: 1.5rem;
    padding: 1rem;
    background: #e8f5e9;
    border-radius: 4px;
    font-style: italic;
  }

  .cta {
    padding: 2rem;
    background: var(--color-bg-light);
    border-radius: 8px;
    height: fit-content;
  }

  .cta h2 {
    color: var(--color-primary);
    font-size: 1.25rem;
    margin-top: 0;
  }
</style>
