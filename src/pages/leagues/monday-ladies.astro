---
import LeaguePage from '../../components/LeaguePage.astro';
---

<LeaguePage
  name="Monday Ladies League"
  day="Monday"
  time="Tee times starting at 4:00 PM"
  description="Weekly ladies golf league running throughout the summer season."
>
  <div slot="announcements">
    <div class="announcement">
      <p><strong>Reminder:</strong> Please write FULL NAMES OF SUBS on scorecards and turn in at the bar when done!</p>
    </div>

    <!-- Add more announcements here as needed -->
    <!--
    <div class="announcement">
      <h4>Week 10 Results</h4>
      <p>Chip-ins: Jane Doe on #3, Mary Smith on #7</p>
      <p>Birdies: Susan Johnson on #5</p>
    </div>
    -->
  </div>

  <div slot="season-info">
    <p>The Monday Ladies League runs from May through August. New members are welcome!</p>
    <h4>Tee Time Booking</h4>
    <p>Members can reserve tee times up to 6 days in advance starting Tuesdays at 8 AM through:</p>
    <ul>
      <li>Phone: <a href="tel:920-779-6421">(920) 779-6421</a></li>
      <li>Online: <a href="https://www.chronogolf.com/club/grand-view-golf-club" target="_blank" rel="noopener">Chronogolf</a></li>
      <li>Mobile App</li>
      <li>In-person at the clubhouse Monday evenings</li>
    </ul>
  </div>

  <div slot="documents">
    <ul class="doc-list">
      <!-- TODO: Add actual document links -->
      <li><a href="/documents/leagues/monday-ladies/schedule.pdf">Schedule & Roster</a></li>
      <li><a href="/documents/leagues/monday-ladies/rules.pdf">League Rules</a></li>
      <li><a href="/documents/leagues/monday-ladies/subs.pdf">Substitute List</a></li>
      <li><a href="/documents/leagues/monday-ladies/pairings.pdf">Current Pairings</a></li>
      <li><a href="/documents/leagues/monday-ladies/standings.pdf">Team Standings</a></li>
      <li><a href="/documents/leagues/monday-ladies/scores.pdf">Score History</a></li>
    </ul>
  </div>
</LeaguePage>

<style>
  .announcement {
    padding: 1rem;
    background: var(--color-bg-light);
    border-left: 3px solid var(--color-primary);
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .announcement h4 {
    margin-bottom: 0.5rem;
    color: var(--color-primary);
  }

  .announcement p:last-child {
    margin-bottom: 0;
  }

  h4 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  ul {
    padding-left: 1.5rem;
  }

  li {
    margin-bottom: 0.25rem;
  }
</style>
